@page "/admin/scholars"
@attribute [Authorize(Roles = AppRoles.Admin)]
@using AlSoque.Data.Entities
@using AlSoque.Web.Features.Admin.Scholars
@inject AdminScholarsService ScholarsService

<PageTitle>إدارة العلماء — الإدارة</PageTitle>

<section class="page-hero">
    <h1>إدارة العلماء</h1>
</section>

@if (errorMessage is not null)
{
    <p class="field-error mb-4">@errorMessage</p>
}

<div class="mb-6">
    <a class="btn btn-primary" href="/admin/scholars/0/edit">إضافة عالم جديد</a>
</div>

@if (scholars is null)
{
    <p class="text-ink-soft">جارٍ التحميل...</p>
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead><tr><th>الاسم</th><th>الأسرة</th><th>الوفاة (هـ)</th><th></th></tr></thead>
            <tbody>
                @foreach (var scholar in scholars)
                {
                    <tr>
                        <td>@scholar.FullName</td>
                        <td>@(scholar.Family?.Name ?? "—")</td>
                        <td>@(scholar.AlWufat?.ToString() ?? "—")</td>
                        <td class="flex gap-2">
                            <a class="btn btn-outline" href="@($"/scholars/{scholar.Slug}")">عرض</a>
                            <a class="btn btn-outline" href="@($"/admin/scholars/{scholar.Id}/edit")">تعديل</a>
                            <button class="btn btn-outline" @onclick="() => DeleteAsync(scholar.Id)">حذف</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Scholar>? scholars;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => scholars = await ScholarsService.GetAllAsync();

    private async Task DeleteAsync(int id)
    {
        errorMessage = null;
        try
        {
            await ScholarsService.DeleteAsync(id);
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
    }
}
